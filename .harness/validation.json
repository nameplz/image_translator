{
  "language": "python",
  "stack": "python",
  "package_manager": "uv",
  "commands": [
    {
      "name": "test",
      "command": [
        "uv",
        "run",
        "pytest",
        "-q"
      ],
      "reason": "Run Python tests"
    },
    {
      "name": "coverage",
      "command": [
        "uv",
        "run",
        "pytest",
        "--cov=src",
        "--cov-report=term-missing",
        "--cov-fail-under=80"
      ],
      "reason": "Verify Python test coverage"
    },
    {
      "name": "lint",
      "command": [
        "uv",
        "run",
        "ruff",
        "check",
        "."
      ],
      "reason": "Run Python lint rules"
    },
    {
      "name": "typecheck",
      "command": [
        "uv",
        "run",
        "mypy",
        "src"
      ],
      "reason": "Run Python type checks"
    },
    {
      "name": "gui",
      "command": [
        "python3",
        "scripts/run_gui_tests.py"
      ],
      "reason": "Run GUI tests with offscreen Qt when the GUI contract exists"
    }
  ]
}
